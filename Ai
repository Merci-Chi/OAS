<!-- JS -->
<script>
/* ---- XP Counter ---- */
;(function(){
  const el = document.getElementById('xp-counter');
  const target = 12847;
  const dur = 2200;
  const steps = 80;
  const stepVal = target / steps;
  let cur = 0;
  const t = setInterval(() => {
    cur += stepVal;
    if (cur >= target) { cur = target; clearInterval(t); }
    el.textContent = Math.floor(cur).toLocaleString();
  }, dur / steps);
})();

/* ---- Stat bars + level counters animate on scroll ---- */
const statData = [
  { barId:'bar-mind',  lblId:'lbl-mind',  maxLvl:42, pct:85 },
  { barId:'bar-body',  lblId:'lbl-body',  maxLvl:36, pct:72 },
  { barId:'bar-disc',  lblId:'lbl-disc',  maxLvl:50, pct:91 },
  { barId:'bar-focus', lblId:'lbl-focus', maxLvl:39, pct:78 },
];

function animateStat(s, delay) {
  const bar = document.getElementById(s.barId);
  const lbl = document.getElementById(s.lblId);
  const dur = 1600;
  const fps = 60;
  const ticks = Math.round(dur / (1000 / fps));
  let tick = 0;

  setTimeout(() => {
    bar.style.width = s.pct + '%';
    const t = setInterval(() => {
      tick++;
      const ease = 1 - Math.pow(1 - Math.min(tick / ticks, 1), 3);
      lbl.textContent = 'LVL ' + Math.floor(ease * s.maxLvl);
      if (tick >= ticks) { lbl.textContent = 'LVL ' + s.maxLvl; clearInterval(t); }
    }, 1000 / fps);
  }, delay);
}

let barsAnimated = false;
const statsEl = document.getElementById('stats');
const obs = new IntersectionObserver(entries => {
  if (entries[0].isIntersecting && !barsAnimated) {
    barsAnimated = true;
    statData.forEach((s, i) => animateStat(s, i * 120));
  }
}, { threshold: 0.2 });
obs.observe(statsEl);

/* ---- Donation amount selector ---- */
function selectAmt(el) {
  document.querySelectorAll('.amt-btn').forEach(b => b.classList.remove('active'));
  el.classList.add('active');
}

/* ---- Tier selector ---- */
function selectTier(el) {
  document.querySelectorAll('.tier').forEach(t => t.style.borderColor = '');
  el.style.borderColor = 'rgba(245,158,11,.7)';
}

/* ---- Particles ---- */
;(function(){
  const c = document.getElementById('particles');
  for (let i = 0; i < 36; i++) {
    const p = document.createElement('div');
    p.className = 'particle';
    p.style.left = Math.random() * 100 + '%';
    p.style.top  = Math.random() * 100 + '%';
    p.style.animationDuration = (8 + Math.random() * 14) + 's';
    p.style.animationDelay   = (Math.random() * 12) + 's';
    p.style.opacity = (Math.random() * .4).toString();
    c.appendChild(p);
  }
})();
</script>

